PORT=3000
INVITE_CODE=

# Turso (remote SQLite — required for Render free tier, optional for local dev)
# Create a free database at https://turso.tech, then:
#   turso db create torrent-rss
#   turso db tokens create torrent-rss
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# If TURSO_DATABASE_URL is not set, falls back to a local SQLite file:
# DATABASE_PATH is no longer used — set TURSO_DATABASE_URL=file:./data/torrent-rss.db
# for a local file path override.
